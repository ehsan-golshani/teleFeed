      "id": 0,
      "message": "\u003ci class=\"emoji\" style=\"background-image:url(\u0026#39;//telegram.org/img/emoji/40/F09F94B4.png\u0026#39;)\"\u003e\u003cb\u003e🔴\u003c/b\u003e\u003c/i\u003eمقامات ایران با هدف قرار دادن وکلای مدافع از طریق بازداشت و ارعاب، در حال تخریب آخرین خط حفاظتی از حقوق زندانیان هستند. \u003cbr/\u003e‏در این سیستم قضایی غیرشفاف، وکلای مستقل با اتهامات واهی، محدودیت‌های شدید و تهدید همیشگی بازداشت روبرو هستند. \u003cbr/\u003e‏ترکیب \u0026#34;سرکوبِ وکلا\u0026#34;، \u0026#34;قطع اینترنت\u0026#34; و \u0026#34;تهدید خانواده‌ها\u0026#34;، و جرم‌انگاری هرگونه اطلاع‌رسانی، زنگ خطر فاجعه‌ای انسانی در تضییع حقوق زندانیان را به صدا درآورده است.\u003cbr/\u003e‏⁧ \u003ca href=\"?q=%23%D9%85%D8%AF%D8%A7%D9%81%D8%B9%D8%A7%D9%86_%D8%AD%D9%82%D9%88%D9%82%E2%80%8C%D8%A8%D8%B4%D8%B1\"\u003e#مدافعان_حقوق‌بشر\u003c/a\u003e\u003cbr/\u003e\u003ca href=\"?q=%23%D8%B3%D8%B1%DA%A9%D9%88%D8%A8_%D9%88%DA%A9%D9%84%D8%A7\"\u003e#سرکوب_وکلا\u003c/a\u003e\u003cbr/\u003e\u003cbr/\u003e\u003ca href=\"https://t.me/IranRights\" target=\"_blank\"\u003e@IranRights\u003c/a\u003e⁩",
